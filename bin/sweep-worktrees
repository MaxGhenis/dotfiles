#!/usr/bin/env bash
# sweep-worktrees — classify and remove merged-and-clean git worktrees.
#
# Usage:
#   sweep-worktrees [REPO_DIR ...]         # classify + remove safe ones
#   sweep-worktrees --dry-run REPO_DIR     # classify only
#   sweep-worktrees --force-dirty REPO_DIR # also remove merged worktrees with dirty working tree
#
# If no REPO_DIR given, operates on the current git repo.
#
# For each non-primary worktree:
#   - MERGED (HEAD is ancestor of origin/<default>) + clean → remove worktree, delete branch
#   - MERGED + dirty                                        → report (leave; often generated files)
#   - UNMERGED or DETACHED                                  → leave (real work)
#
# Exit 0 always; prints a one-line classification per worktree.

set -u

DRY_RUN=0
FORCE_DIRTY=0
ARGS=()

# Files that frequently drift without semantic meaning (regenerated by dep
# managers in fresh worktrees). If the only dirty files in a merged
# worktree match these, treat as benign and remove.
BENIGN_DIRTY_PATTERNS='^(uv\.lock|Cargo\.lock|bun\.lock|bun\.lockb|package-lock\.json|yarn\.lock|pnpm-lock\.yaml|poetry\.lock|Pipfile\.lock)$'

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    --force-dirty) FORCE_DIRTY=1; shift ;;
    -h|--help)
      sed -n 's/^# \{0,1\}//p' "$0" | head -20
      exit 0
      ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

if [ ${#ARGS[@]} -eq 0 ]; then
  ARGS=("$(pwd)")
fi

sweep_repo() {
  local repo_dir=$1
  cd "$repo_dir" || { echo "SKIP: $repo_dir (cannot cd)"; return; }

  local default
  default=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|origin/||')
  [ -z "$default" ] && default="main"
  git fetch --quiet origin "$default" 2>/dev/null || true
  local base="origin/$default"

  echo "=== $(basename "$repo_dir") (base: $base) ==="

  git worktree list --porcelain | awk '
    /^worktree / {wt=$2}
    /^branch / {br=$2; print wt "\t" br}
    /^detached/ {print wt "\tDETACHED"}
  ' | while IFS=$'\t' read -r wt branchref; do
    [ "$wt" = "$repo_dir" ] && continue
    local branch=${branchref#refs/heads/}
    local dirty merged head

    if [ -d "$wt" ]; then
      dirty=$(git -C "$wt" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
      # Check whether all dirty files are in the benign list (lock files etc.)
      if [ "$dirty" != "0" ]; then
        local non_benign
        non_benign=$(git -C "$wt" status --porcelain 2>/dev/null \
          | awk '{print $NF}' \
          | grep -Ev "$BENIGN_DIRTY_PATTERNS" | wc -l | tr -d ' ')
        if [ "$non_benign" = "0" ]; then
          benign_only="yes"
        else
          benign_only="no"
        fi
      else
        benign_only="n/a"
      fi
    else
      dirty="missing"
      benign_only="n/a"
    fi

    if [ "$branchref" = "DETACHED" ] || [ -z "$branch" ]; then
      merged="detached"
    else
      head=$(git -C "$wt" rev-parse HEAD 2>/dev/null || echo "")
      if [ -n "$head" ] && git merge-base --is-ancestor "$head" "$base" 2>/dev/null; then
        merged="merged"
      else
        merged="unmerged"
      fi
    fi

    local safe_to_remove="no"
    if [ "$merged" = "merged" ]; then
      if [ "$dirty" = "0" ] || [ "$benign_only" = "yes" ] || [ "$FORCE_DIRTY" = "1" ]; then
        safe_to_remove="yes"
      fi
    fi

    if [ "$safe_to_remove" = "yes" ]; then
      local tag="clean"
      [ "$benign_only" = "yes" ] && tag="benign-dirty"
      [ "$FORCE_DIRTY" = "1" ] && [ "$benign_only" != "yes" ] && [ "$dirty" != "0" ] && tag="forced"
      if [ "$DRY_RUN" = "1" ]; then
        echo "WOULD-REMOVE: $wt ($branch) [$tag, dirty=$dirty]"
      else
        echo "REMOVE: $wt ($branch) [$tag]"
        if [ "$dirty" != "0" ]; then
          git worktree remove --force "$wt" 2>&1 | sed 's|^|  |'
        else
          git worktree remove "$wt" 2>&1 | sed 's|^|  |'
        fi
        [ -n "$branch" ] && git branch -D "$branch" 2>&1 | sed 's|^|  |'
      fi
    elif [ "$merged" = "merged" ]; then
      echo "MERGED-BUT-DIRTY: $wt ($branch) [$dirty files, non-benign]"
    elif [ "$merged" = "detached" ]; then
      echo "DETACHED: $wt"
    else
      echo "UNMERGED: $wt ($branch) [dirty=$dirty]"
    fi
  done

  git worktree prune
}

for repo in "${ARGS[@]}"; do
  sweep_repo "$repo"
done
